@page
@model ChatApplication.Pages.ChatPageModel
@{
    ViewData["Title"] = "Chat";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

<style>
    body {
        font-family: Arial, sans-serif;
        background: #f0f2f5;
        margin: 0;
        padding: 0;

    }

    .chat-container {
        display: flex;
        height: 90vh;
        width: 100%;
        border-radius: 10px;
        overflow: hidden;
        background: white;
        box-shadow: 0px 2px 10px rgba(0, 0, 0, 0.1);
    }

    .chat-sidebar {
        width: 30%;
        background: #ffffff;
        padding: 20px;
        overflow-y: auto;
        border-right: 1px solid #ddd;
        display: flex;
        flex-direction: column;
    }

    .sidebar-header {
        font-size: 1.5rem;
        font-weight: bold;
        margin-bottom: 20px;
    }

    .chat-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .chat-item {
        display: flex;
        align-items: center;
        padding: 10px;
        margin-bottom: 10px;
        border-radius: 8px;
        transition: background-color 0.3s ease;
        cursor: pointer;
    }

    .chat-item:hover {
        background-color: #f1f1f1;
    }

    .chat-item i {
        margin-right: 10px;
        font-size: 20px;
        color: #25D366;
        /* WhatsApp green */
    }

    .chat-item span {
        font-size: 1rem;
        color: #333;
    }

    .chat-item.active {
        background-color: #e1f7d5;
    }

    .chat-area {
        width: 70%;
        display: flex;
        flex-direction: column;
        background: #e5ddd5;
        position: relative;
    }

    .chat-messages {
        flex-grow: 1;
        padding: 15px;
        overflow-y: auto;
    }

    .chat-message {
        display: flex;
        align-items: flex-end;
        gap: 8px;
        padding: 8px 12px;
        margin: 8px;
        border-radius: 8px;
        max-width: 70%;
    }

    .chat-title {
        background-color: #ffffff;
        padding: 15px 20px;
        font-size: 1.25rem;
        font-weight: bold;
        color: #333;
        border-bottom: 2px solid #ddd;
        align-items: center;
        display: flex;
        gap: 12px;
        border-radius: 0 0 10px 10px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        margin-bottom: 20px;
    }
    .chat-title-img {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: #eee;
        object-fit: cover;
    }
    .chat-title-info {
        display: flex;
        flex-direction: column;
    }
    .chat-title-name {
        font-weight: bold;
        font-size: 1.1rem;
    }
    .chat-title-status {
        font-size: 0.9rem;
        color: #888;
    }
    .chat-message.sent {
        background: #dcf8c6;
        align-self: flex-end;
        text-align: right;
        flex-direction: row-reverse;
    }
    .chat-message.received {
        background: white;
        align-self: flex-start;
        text-align: left;
    }
    .chat-message-img {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #eee;
        object-fit: cover;
    }
    .chat-message-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-width: 0;
    }
    .chat-message-header {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 2px;
    }
    .chat-message-name {
        font-weight: bold;
        font-size: 0.95rem;
        color: #333;
        margin-right: 6px;
    }
    .chat-message-time {
        font-size: 0.8rem;
        color: #999;
    }

    .input-area {
        display: flex;
        padding: 10px;
        background: white;
        border-top: 1px solid #ddd;
    }

    .input-area input {
        flex-grow: 1;
        padding: 8px;
        border: none;
        border-radius: 5px;
        margin-right: 10px;
    }

    .input-area button {
        background: #25D366;
        border: none;
        padding: 10px 15px;
        border-radius: 5px;
        color: white;
        cursor: pointer;
    }

    .input-area button:hover {
        background: #1ebe57;
    }

    .sidebar-profile {
        display: flex;
        align-items: center;
        padding-bottom: 15px;
        border-bottom: 1px solid #eee;
        margin-bottom: 15px;
    }
    .sidebar-profile-img {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #ddd;
        margin-right: 12px;
        object-fit: cover;
    }
    .sidebar-profile-info {
        display: flex;
        flex-direction: column;
    }
    .sidebar-profile-name {
        font-weight: bold;
        font-size: 1.1rem;
    }
    .sidebar-profile-email {
        font-size: 0.9rem;
        color: #888;
    }
    .sidebar-search {
        margin: 15px 0 20px 0;
    }
    .sidebar-search input {
        width: 100%;
        padding: 8px 12px;
        border-radius: 20px;
        border: 1px solid #ddd;
        background: #f6f6f6;
        font-size: 1rem;
    }
    .chat-item-img {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #eee;
        margin-right: 12px;
        object-fit: cover;
    }
    .chat-item-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-width: 0;
    }
    .chat-item-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .chat-item-name {
        font-weight: bold;
        font-size: 1rem;
        color: #333;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .chat-item-time {
        font-size: 0.85rem;
        color: #999;
        margin-left: 8px;
        white-space: nowrap;
    }
    .chat-item-lastmsg {
        font-size: 0.95rem;
        color: #666;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>

<div class="chat-container">
    <div class="chat-sidebar">
        <div class="sidebar-profile">
            <img src="/wwwroot/img/profile_placeholder.png" class="sidebar-profile-img" alt="Profil" />
            <div class="sidebar-profile-info">
                <span class="sidebar-profile-name">@User.Identity?.Name</span>
                <span class="sidebar-profile-email">@User.FindFirst("Email")?.Value</span>
            </div>
        </div>
        <div class="sidebar-search">
            <input type="text" placeholder="Sohbetlerde ara..." />
        </div>
        <div class="sidebar-header">Sohbetler</div>
        <ul class="chat-list">
            @foreach (var item in Model.ChatList)
            {
                if (item.IsGroup)
                {
                    <a asp-page="/ChatPage" asp-route-groupId="@item.Id">
                        <li class="chat-item @((item.Id == Model.GroupId) ? "active" : "")">
                            <img src="@item.ProfileImageUrl" class="chat-item-img" alt="Grup" />
                            <div class="chat-item-content">
                                <div class="chat-item-header">
                                    <span class="chat-item-name">@item.Name</span>
                                    <span class="chat-item-time">@(item.LastMessageTime?.ToString("HH:mm") ?? "")</span>
                                </div>
                                <span class="chat-item-lastmsg">@item.LastMessage</span>
                            </div>
                        </li>
                    </a>
                }
                else
                {
                    <a asp-page="/ChatPage" asp-route-receiverId="@item.Id">
                        <li class="chat-item @((item.Id == Model.ReceiverId) ? "active" : "")">
                            <img src="@item.ProfileImageUrl" class="chat-item-img" alt="Kullanıcı" />
                            <div class="chat-item-content">
                                <div class="chat-item-header">
                                    <span class="chat-item-name">@item.Name</span>
                                    <span class="chat-item-time">@(item.LastMessageTime?.ToString("HH:mm") ?? "")</span>
                                </div>
                                <span class="chat-item-lastmsg">@item.LastMessage</span>
                            </div>
                        </li>
                    </a>
                }
            }
        </ul>
    </div>

    <div class="chat-area">
        <div class="chat-title">
            <img src="/wwwroot/img/profile_placeholder.png" class="chat-title-img" alt="Profil" />
            <div class="chat-title-info">
                <span class="chat-title-name">@Model.ChatTitle</span>
                <span class="chat-title-status">Çevrimiçi</span>
            </div>
        </div>
        <div class="chat-messages" id="chatMessages">
            @foreach (var message in Model.MessagesVm)
            {
                <div class="chat-message @(message.SenderId == Model.CurrentUserId ? "sent" : "received")">
                    <img src="@message.SenderProfileImageUrl" class="chat-message-img" alt="Profil" />
                    <div class="chat-message-content">
                        <div class="chat-message-header">
                            <span class="chat-message-name">@(message.SenderId == Model.CurrentUserId ? "Sen" : message.SenderName)</span>
                            <span class="chat-message-time">@message.CreatedAt.ToString("HH:mm")</span>
                        </div>
                        <span>@message.Text</span>
                        @if (!string.IsNullOrEmpty(message.FileUrl))
                        {
                            if (message.FileUrl.EndsWith(".jpg") || message.FileUrl.EndsWith(".jpeg") || message.FileUrl.EndsWith(".png") || message.FileUrl.EndsWith(".gif"))
                            {
                                <div style="margin-top:6px;"><img src="@message.FileUrl" alt="Dosya" style="max-width:180px; max-height:180px; border-radius:8px;" /></div>
                            }
                            else
                            {
                                <div style="margin-top:6px;"><a href="@message.FileUrl" target="_blank">Dosyayı indir</a></div>
                            }
                        }
                    </div>
                </div>
            }
        </div>

        <form method="post" class="input-area" id="messageForm" enctype="multipart/form-data">
            <input type="hidden" name="groupId" id="groupId" value="@Model.GroupId" />
            <input type="hidden" name="receiverId" id="receiverId" value="@Model.ReceiverId" />
            <label for="fileInput" style="margin-right:8px; cursor:pointer;">
                <i class="fa fa-paperclip" style="font-size: 1.3rem; color: #888;"></i>
            </label>
            <input type="file" id="fileInput" name="file" style="display:none;" />
            <input type="text" asp-for="MessageText" id="messageText" placeholder="Type a message..." required />
            <button type="submit" onclick="sendMessage()"><i class="fa fa-paper-plane"></i></button>
        </form>

    </div>
</div>
<script>
    var connection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .build();

    connection.start().then(function () {
        console.log("SignalR bağlantısı başarılı.");
    }).catch(function (err) {
        console.error("SignalR bağlantı hatası:", err.toString());
    });

    connection.on("ReceiveMessage", function (senderId, message) {
        console.log("Gelen mesaj:", message);  
        var chatMessages = document.getElementById("chatMessages");
        var newMessage = document.createElement("div");
        newMessage.textContent = message; 
        chatMessages.appendChild(newMessage);
    });

    function sendMessage(event) {
        var messageText = document.getElementById("messageText").value;
        var groupId = document.getElementById("groupId").value;
        var receiverId = document.getElementById("receiverId").value;

        if (messageText.trim() === "") {
            console.log("Boş mesaj gönderilemez.");
            return;
        }

        console.log("Gönderilen veriler:", {
            messageText,
            groupId,
            receiverId
        });

        if (receiverId.trim() === "") {
            connection.invoke("SendMessage", 1, null, parseInt(groupId), messageText)
                .then(() => {
                    console.log("Mesaj SignalR ile gönderildi.");
                    document.getElementById("messageText").value = ""; 
                })
                .catch(function (err) {
                    console.error("Mesaj gönderilirken hata oluştu:", err.toString());
                });
        } else {
            connection.invoke("SendMessage", 1, parseInt(receiverId), null, messageText)
                .then(() => {
                    console.log("Mesaj SignalR ile gönderildi.");
                    document.getElementById("messageText").value = ""; 
                })
                .catch(function (err) {
                    console.error("Mesaj gönderilirken hata oluştu:", err.toString());
                });
        }

        // Formun submit işlemini engelle
        event.preventDefault(); // Formu normal şekilde gönderme
    }


</script>

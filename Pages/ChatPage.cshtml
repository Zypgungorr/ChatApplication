@page
@model ChatApplication.Pages.ChatPageModel
@{
    ViewData["Title"] = "Chat";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

<style>
    body {
        font-family: Arial, sans-serif;
        margin: 0;
        padding: 0;
        background: #f0f2f5;
    }

    /* Chat container setup */
    .chat-container {
        display: flex;
        height: 90vh;
        width: 100%;
        border-radius: 10px;
        overflow: hidden;
        background: white;
        box-shadow: 0px 2px 10px rgba(0, 0, 0, 0.1);
    }

    /* Chat Sidebar Styles */
    .chat-sidebar {
        width: 30%;
        background: #ffffff;
        padding: 20px;
        overflow-y: auto;
        border-right: 1px solid #ddd;
        display: flex;
        flex-direction: column;
    }

    .sidebar-header {
        font-size: 1.5rem;
        font-weight: bold;
        margin-bottom: 20px;
    }

    .chat-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .chat-item {
        display: flex;
        align-items: center;
        padding: 10px;
        margin-bottom: 10px;
        border-radius: 8px;
        transition: background-color 0.3s ease;
        cursor: pointer;
    }

    .chat-item:hover {
        background-color: #f1f1f1;
    }

    .chat-item i {
        margin-right: 10px;
        font-size: 20px;
        color: #25D366;
        /* WhatsApp green */
    }

    .chat-item span {
        font-size: 1rem;
        color: #333;
    }

    /* Active state for selected chat */
    .chat-item.active {
        background-color: #e1f7d5;
    }

    /* Chat area styling */
    .chat-area {
        width: 70%;
        display: flex;
        flex-direction: column;
        background: #e5ddd5;
        position: relative;
    }

    .chat-messages {
        flex-grow: 1;
        padding: 15px;
        overflow-y: scroll;
    }

    .chat-message {
        padding: 8px 12px;
        margin: 8px;
        border-radius: 8px;
        max-width: 70%;
    }

    .chat-title {
        background-color: #ffffff;
        padding: 15px 20px;
        font-size: 1.25rem;
        font-weight: bold;
        color: #333;
        border-bottom: 2px solid #ddd;
        align-items:flex-start;
        justify-content: space-between;
        border-radius: 0 0 10px 10px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        margin-bottom: 20px;
    }

    .chat-title i {
        font-size: 1.5rem;
        color: #25D366;
        margin-right: 10px;
    }


    .sent {
        background: #dcf8c6;
        align-self: flex-end;
        text-align: right;
    }

    .received {
        background: white;
        align-self: flex-start;
        text-align: left;
    }

    /* Input area */
    .input-area {
        display: flex;
        padding: 10px;
        background: white;
        border-top: 1px solid #ddd;
    }

    .input-area input {
        flex-grow: 1;
        padding: 8px;
        border: none;
        border-radius: 5px;
        margin-right: 10px;
    }

    .input-area button {
        background: #25D366;
        border: none;
        padding: 10px 15px;
        border-radius: 5px;
        color: white;
        cursor: pointer;
    }

    .input-area button:hover {
        background: #1ebe57;
    }
</style>

<div class="chat-container">
    <!-- Left Sidebar: Groups & Users -->
    <div class="chat-sidebar">
        <div class="sidebar-header">Sohbetler</div>
        <ul class="chat-list">
            <!-- Group chats -->
            @foreach (var group in Model.Groups)
            {
                <a asp-page="/ChatPage" asp-route-groupId="@group.Id">
                    <li class="chat-item @((group.Id == Model.GroupId) ? "active" : "")">
                        <i class="fa fa-users"></i>
                        <span>@group.GroupName</span>
                    </li>
                </a>
            }

            <!-- Individual Chats -->
            @foreach (var user in Model.Users)
            {
                <a asp-page="/ChatPage" asp-route-receiverId="@user.Id">
                    <li class="chat-item @((user.Id == Model.ReceiverId) ? "active" : "")">
                        <i class="fa fa-user"></i>
                        <span>@user.Username</span>
                    </li>
                </a>

            }
        </ul>
    </div>

    <!-- Chat Area -->
    <div class="chat-area">
  
        <div class="chat-title">
            <i class="fa fa-comments"></i> <!-- Icon can be customized -->
            @Model.ChatTitle
        </div>
        <div class="chat-messages">
            @foreach (var message in Model.Messages)
            {
                <div class="chat-message @(message.SenderId == Model.CurrentUserId ? "sent" : "received")">
                    @message.Text
                </div>
            }
        </div>

        <!-- Send Message Area -->
        <form method="post" class="input-area">
            <input type="hidden" name="groupId" value="@Model.GroupId" />
            <input type="hidden" name="receiverId" value="@Model.ReceiverId" />
            <input type="text" asp-for="MessageText" placeholder="Type a message..." required />
            <button type="submit"><i class="fa fa-paper-plane"></i></button>
        </form>
    </div>
</div>


